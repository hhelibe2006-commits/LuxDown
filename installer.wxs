<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="LuxDown"
           Codepage="65001"
           Manufacturer="hhelibe"
           Version="1.0.3"
           Scope="perMachine"
           UpgradeCode="B9A3F1C4-7D6E-4A2B-8C9D-EAF012345678">

    <MajorUpgrade DowngradeErrorMessage="已安装更高版本，无法覆盖。" />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="LuxDown" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <Feature Id="Main" Title="主程序" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="DesktopShortcut" />
    </Feature>
  </Package>

  <Fragment>
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="build\main.dist\**" />
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="DesktopShortcut" Directory="INSTALLFOLDER">
      <Component Id="MainExeAndShortcut" Guid="A1B2C3D4-E5F6-7A8B-9C0D-E1F2A3B4C5D6">
        <File Id="MainExe" Source="build\main.dist\LuxDown.exe" />
        <Shortcut Id="DesktopShortcut"
                  Directory="DesktopFolder"
                  Name="LuxDown"
                  WorkingDirectory="INSTALLFOLDER"
                  Advertise="no" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>